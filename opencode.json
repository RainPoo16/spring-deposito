{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".github/copilot-instructions.md",
    ".github/instructions/api-design-patterns.instructions.md",
    ".github/instructions/code-reviewer.instructions.md",
    ".github/instructions/configuration-patterns.instructions.md",
    ".github/instructions/database-jpa-patterns.instructions.md",
    ".github/instructions/instructions.instructions.md",
    ".github/instructions/java-spring-coding-standards.instructions.md",
    ".github/instructions/pii-protection.instructions.md",
    ".github/instructions/prompt.instructions.md"
  ],
  "agent": {
    "Atlas": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.2-codex",
      "prompt": "{file:.github/agents/Atlas.agent.md}",
      "variant": "max",
      "color": "#FFC0CB"
    },
    "Prometheus": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.2-codex",
      "prompt": "{file:.github/agents/Prometheus.agent.md}",
      "variant": "max",
      "color": "#00FFFF"
    },
    "Code-Review-subagent": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "hidden": true,
      "prompt": "{file:.github/agents/Code-Review-subagent.agent.md}"
    },
    "Explorer-subagent": {
      "mode": "subagent",
      "model": "github-copilot/gemini-3-flash-preview",
      "hidden": true,
      "prompt": "{file:.github/agents/Explorer-subagent.agent.md}"
    },
    "Frontend-Engineer-subagent": {
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "hidden": true,
      "prompt": "{file:.github/agents/Frontend-Engineer-subagent.agent.md}"
    },
    "Oracle-subagent": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "hidden": true,
      "prompt": "{file:.github/agents/Oracle-subagent.agent.md}"
    },
    "Sisyphus-subagent": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.2-codex",
      "hidden": true,
      "prompt": "{file:.github/agents/Sisyphus-subagent.agent.md}"
    }
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "grep-app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  }
}
